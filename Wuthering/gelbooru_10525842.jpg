	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/14/0f/140f3ae44dea6dad99510267ec07ea77.jpg');
		  image.width('1920');
			image.height('1080');
			image.toggleClass('fit-width');
				image.on("load", function() {
			image.css("animation", "sharpen 0.5s forwards");
		});

  	}
