	var imageTags = "";
	function navigatePrev()
	{
		$.get( "apiTest.php", { id:10525842, tags: imageTags, nextPrev: 'next' }, function( data ) {
			window.location.href = data;
		});
	}

	function navigateNext()
	{
		$.get( "apiTest.php", { id:10525842, tags: imageTags, nextPrev: 'prev' }, function( data ) {
		window.location.href = data;
