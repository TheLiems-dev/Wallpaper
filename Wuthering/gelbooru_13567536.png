	});
	var imageTags = "";
	function navigatePrev()
	{
		$.get( "apiTest.php", { id:13567536, tags: imageTags, nextPrev: 'next' }, function( data ) {
			window.location.href = data;
		});
	}

	function navigateNext()
	{
		$.get( "apiTest.php", { id:13567536, tags: imageTags, nextPrev: 'prev' }, function( data ) {
		window.location.href = data;
		});
	}
	$("#navNext").click(function() {
		navigateNext();
	});
	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/26/b5/26b5955628090281179cba72e9711268.png');
		  image.width('3200');
			image.height('2400');
			image.toggleClass('fit-width');
				image.on("load", function() {
			image.css("animation", "sharpen 0.5s forwards");
		});

  	}
	</script>