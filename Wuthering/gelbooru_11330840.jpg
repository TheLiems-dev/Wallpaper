	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/86/b8/86b815cce85f855a90ba596277408dac.jpg');
		  image.width('3000');
			image.height('2068');
