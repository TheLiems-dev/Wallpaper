	<script type="text/javascript">
		function tagPM(tagInput){
			$('#tags-search').val($('#tags-search').val() + ' ' + tagInput);
		}

		function saveTagSearch() {
			$.post("index.php?page=tags&s=saved_search&csrf-token=f1cbf14d5eebfaa093bc2389885ccd40d92076b412c007a7a0be1ef93608b9a1", { save_tag_search: $('#tags-search').val()} )
			  .done(function( data ) {
				if(data)
				{
					notice("Saved this search successfully! You can access these via the Tags link in the header.");
				}
				else
				{
					notice("There was an error saving this search. Perhaps it already existed or you are not logged in?");
				}
			  });;
		}
		if($.cookie('motd') == 1)
		{
			$("#motd").hide();
		}

		function darkModeToggle()
		{
			if ($.cookie('dark_mode') == 1 )
			{
				$.removeCookie("dark_mode");
			}
			else
			{
				$.cookie("dark_mode", 1, { expires : 365 });
			}
			location.reload();
		}
	</script>

