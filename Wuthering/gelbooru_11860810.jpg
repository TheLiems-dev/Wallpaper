	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/32/bb/32bb094d219820d7c4779bdd6ad98f44.jpg');
