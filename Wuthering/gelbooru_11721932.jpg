	});
	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/27/06/2706c44cbd543633aa1c86bed7593982.jpg');
		  image.width('1364');
			image.height('2048');
			image.toggleClass('fit-width');
				image.on("load", function() {
			image.css("animation", "sharpen 0.5s forwards");
		});

  	}
	</script>