		addFav('11721932');
	});
	var imageTags = "";
	function navigatePrev()
	{
		$.get( "apiTest.php", { id:11721932, tags: imageTags, nextPrev: 'next' }, function( data ) {
			window.location.href = data;
		});
	}

	function navigateNext()
	{
		$.get( "apiTest.php", { id:11721932, tags: imageTags, nextPrev: 'prev' }, function( data ) {
		window.location.href = data;
		});
	}
