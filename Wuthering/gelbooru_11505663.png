	});
	var imageTags = "";
	function navigatePrev()
	{
		$.get( "apiTest.php", { id:11505663, tags: imageTags, nextPrev: 'next' }, function( data ) {
			window.location.href = data;
		});
	}

	function navigateNext()
	{
		$.get( "apiTest.php", { id:11505663, tags: imageTags, nextPrev: 'prev' }, function( data ) {
		window.location.href = data;
		});
	}
	$("#navNext").click(function() {
		navigateNext();
	});
	function resizeTransition()
	{
		var image = $("#image");
		image.css("filter", "blur(8px)");
		$('#resize-link').toggle();
		image.attr('src','https://img4.gelbooru.com/images/4a/50/4a5064ecd0ca42936a37335d9ca97158.png');
		  image.width('1530');
			image.height('2200');
			image.toggleClass('fit-width');
				image.on("load", function() {
			image.css("animation", "sharpen 0.5s forwards");
		});

  	}
	</script>