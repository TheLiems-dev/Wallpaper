				}
				else
				{
					notice("There was an error saving this search. Perhaps it already existed or you are not logged in?");
				}
			  });;
		}
		if($.cookie('motd') == 1)
		{
			$("#motd").hide();
		}

		function darkModeToggle()
		{
			if ($.cookie('dark_mode') == 1 )
			{
				$.removeCookie("dark_mode");
			}
			else
			{
				$.cookie("dark_mode", 1, { expires : 365 });
			}
			location.reload();
		}
	</script>

